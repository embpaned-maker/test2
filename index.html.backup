<!DOCTYPE html>
<html lang="ro">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Oglinda Oglinjoara – Photo Booth Premium Moldova</title>
<meta name="description" content="Photo Booth Premium pentru nunți, cumetrii, aniversări, corporate. Fotografii printate instant. Activi în toată Moldova.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,700;1,400;1,500&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
/* ─────────────────────────────────────────
   TOKENS
───────────────────────────────────────── */
:root {
  --gold:        #F0BB0C;
  --gold-hover:  #E0AD00;
  --gold-pale:   #FEF8DC;
  --gold-border: rgba(240,187,12,0.22);
  --dark:        #17140D;
  --dark2:       #211E15;
  --ink:         #2E2A1E;
  --muted:       #7A7060;
  --cream:       #FBFAF5;
  --white:       #FFFFFF;
  --border:      rgba(46,42,30,0.1);
  --r:           6px;
  --r-lg:        14px;
  --shadow-sm:   0 2px 12px rgba(23,20,13,.07);
  --shadow-md:   0 8px 32px rgba(23,20,13,.10);
  --shadow-lg:   0 20px 60px rgba(23,20,13,.14);
}

*,*::before,*::after { box-sizing:border-box; margin:0; padding:0; }
html { scroll-behavior:smooth; font-size:16px; }
body {
  font-family:'Inter',sans-serif;
  background:var(--cream);
  color:var(--ink);
  line-height:1.6;
  overflow-x:hidden;
}
img { display:block; max-width:100%; }

/* ── TYPE ── */
.serif { font-family:'Playfair Display',serif; }
h1,h2,h3 { font-family:'Playfair Display',serif; line-height:1.1; }

/* ── LAYOUT ── */
.wrap  { max-width:1160px; margin:0 auto; padding:0 32px; }
.wrap-sm { max-width:820px; margin:0 auto; padding:0 32px; }

/* ── EYEBROW ── */
.eyebrow {
  display:inline-flex; align-items:center; gap:8px;
  font-size:11px; font-weight:600; letter-spacing:.14em; text-transform:uppercase;
  color:var(--gold-hover);
  margin-bottom:20px;
}
.eyebrow-line { width:28px; height:1.5px; background:var(--gold); }

/* ── BUTTONS ── */
.btn {
  display:inline-flex; align-items:center; justify-content:center; gap:8px;
  font-family:'Inter',sans-serif; font-size:14px; font-weight:600;
  letter-spacing:.03em; border:none; border-radius:var(--r);
  cursor:pointer; text-decoration:none; transition:all .18s;
  white-space:nowrap;
}
.btn-gold {
  background:var(--gold); color:var(--dark);
  padding:13px 32px;
  font-size:15px;
  font-weight:700;
  box-shadow:0 4px 18px rgba(240,187,12,.35);
}
.btn-gold:hover { background:var(--gold-hover); transform:translateY(-1px); box-shadow:0 8px 24px rgba(240,187,12,.4); }
.btn-outline {
  background:transparent; color:var(--dark);
  padding:12px 30px;
  font-size:15px;
  border:1.5px solid rgba(46,42,30,.25);
}
.btn-outline:hover { border-color:var(--dark); background:var(--dark); color:var(--white); }
.btn-outline-white {
  background:transparent; color:var(--white);
  padding:13px 28px;
  border:1.5px solid rgba(255,255,255,.35);
}
.btn-outline-white:hover { border-color:var(--white); background:var(--white); color:var(--dark); }

/* ══════════════════════════════════════
   NAVBAR
══════════════════════════════════════ */
#nav {
  position:fixed; top:0; left:0; right:0; z-index:200;
  height:66px;
  display:flex; align-items:center;
  background:rgba(251,250,245,.97);
  backdrop-filter:blur(14px);
  border-bottom:1px solid var(--border);
  padding:0 32px;
  transition:box-shadow .2s;
}
#nav.shadow { box-shadow:var(--shadow-sm); }
.nav-in {
  max-width:1160px; width:100%; margin:0 auto;
  display:flex; align-items:center; justify-content:space-between; gap:24px;
}
.nav-brand {
  display:flex; align-items:center; gap:11px;
  text-decoration:none; flex-shrink:0;
}
.nav-brand img { width:56px; height:56px; border-radius:0; object-fit:contain; }
.nav-brand-name {
  font-family:'Playfair Display',serif; font-size:17px; font-weight:500;
  color:var(--dark); line-height:1.15;
}
.nav-brand-sub {
  font-size:10px; letter-spacing:.12em; text-transform:uppercase;
  color:var(--muted); font-weight:400;
}
.nav-links {
  display:flex; align-items:center; gap:28px; list-style:none;
}
.nav-links a {
  font-size:13px; font-weight:500; color:var(--muted);
  text-decoration:none; transition:color .15s;
}
.nav-links a:hover { color:var(--dark); }
.nav-actions { display:flex; align-items:center; gap:10px; font-size:13px; }

/* ══════════════════════════════════════
   HERO
══════════════════════════════════════ */
.hero {
  min-height:100vh;
  padding-top:66px;
  display:flex; align-items:center;
  background:var(--cream);
  position:relative; overflow:hidden;
}
/* subtle texture glow */
.hero::before {
  content:'';
  position:absolute; top:-200px; right:-100px;
  width:700px; height:700px;
  background:radial-gradient(ellipse, rgba(240,187,12,.09) 0%, transparent 65%);
  pointer-events:none;
}
.hero-grid {
  display:flex; min-height:calc(100vh - 66px);
  position:relative; z-index:1;
  width:100%;
  justify-content:center;
}
/* LEFT PANEL */
.hero-left {
  display:flex; flex-direction:column; justify-content:center; align-items:center;
  padding:80px 40px;
  max-width:760px;
  text-align:center;
}
.hero-title {
  font-size:clamp(40px,4.5vw,66px);
  color:var(--dark);
  margin-bottom:22px;
  font-weight:700;
}
.hero-title em { font-style:italic; color:var(--gold-hover); }
.hero-sub {
  font-size:16px; color:var(--muted); font-weight:300;
  line-height:1.75; max-width:520px; margin-bottom:36px;
}
.hero-btns { display:flex; align-items:center; justify-content:center; gap:14px; flex-wrap:wrap; }
.hero-pills {
  display:flex; flex-wrap:wrap; gap:10px; justify-content:center;
  margin-top:44px; padding-top:36px;
  border-top:1px solid var(--border);
}
.hero-pill {
  display:flex; align-items:center; gap:8px;
  background:var(--white); border:1px solid var(--border);
  border-radius:100px; padding:7px 14px;
  font-size:12px; font-weight:500; color:var(--ink);
  box-shadow:var(--shadow-sm);
}
.hero-pill-dot { width:7px; height:7px; border-radius:50%; background:var(--gold); flex-shrink:0; }

/* RIGHT PANEL — photo collage */
.hero-right {
  background:var(--dark);
  position:relative; overflow:hidden;
  min-height:100%;
}
.hero-collage {
  position:absolute; inset:0;
  display:grid;
  grid-template-columns:1fr 1fr;
  grid-template-rows:1fr 1fr 1fr;
  gap:3px;
}
.hc { position:relative; overflow:hidden; background:var(--dark2); }
.hc-1 { grid-column:1/2; grid-row:1/3; }
.hc-2 { grid-column:2/3; grid-row:1/2; }
.hc-3 { grid-column:2/3; grid-row:2/3; }
.hc-4 { grid-column:1/3; grid-row:3/4; }
.hc-inner {
  position:absolute; inset:0;
  display:flex; align-items:center; justify-content:center;
  flex-direction:column; gap:6px;
  font-family:'Playfair Display',serif;
  font-style:italic; font-size:15px;
  color:rgba(240,187,12,.3);
  background:linear-gradient(135deg, rgba(240,187,12,.04) 0%, transparent 60%);
}
.hc-inner span { font-size:28px; opacity:.45; }

/* overlay gradient on right panel */
.hero-right-overlay {
  position:absolute; inset:0; z-index:2; pointer-events:none;
  background:linear-gradient(to right, rgba(23,20,13,.18) 0%, transparent 40%);
}

/* floating cards */
.hero-card {
  position:absolute; z-index:3;
  background:var(--white);
  border-radius:var(--r-lg);
  box-shadow:var(--shadow-lg);
  padding:16px 20px;
}
.hcard-1 {
  bottom:36px; left:-28px;
  min-width:160px; text-align:center;
  background:var(--gold);
}
.hcard-1 .hc-big {
  font-family:'Playfair Display',serif;
  font-size:38px; font-weight:700; line-height:1;
  color:var(--dark);
}
.hcard-1 .hc-lbl {
  font-size:10px; font-weight:700; letter-spacing:.12em;
  text-transform:uppercase; color:var(--dark); margin-top:4px;
}
.hcard-2 {
  top:28px; right:24px;
  display:flex; align-items:center; gap:10px;
  padding:11px 16px; border-radius:100px;
}
.hcard-2-dot { width:9px; height:9px; border-radius:50%; background:#22C55E; flex-shrink:0; }
.hcard-2-txt { font-size:12px; font-weight:600; color:var(--dark); white-space:nowrap; }
.hcard-3 {
  top:50%; left:50%; transform:translate(-50%,-50%);
  text-align:center; min-width:140px;
  border:1px solid var(--gold-border);
  padding:14px 18px;
}
.hcard-3-n {
  font-family:'Playfair Display',serif;
  font-size:32px; font-weight:700; color:var(--dark); line-height:1;
}
.hcard-3-l { font-size:10px; color:var(--muted); letter-spacing:.08em; text-transform:uppercase; margin-top:3px; }

/* ══════════════════════════════════════
   SHARED SECTION STYLES
══════════════════════════════════════ */
.sec { padding:100px 0; }
.sec-dark { background:var(--dark); }
.sec-white { background:var(--cream); }
.sec-cream { background:var(--cream); }
.sec-head { margin-bottom:56px; }
.sec-head.center { text-align:center; }
.sec-head.center .eyebrow { display:flex; justify-content:center; }
.sec-title {
  font-size:clamp(28px,3.5vw,46px);
  color:var(--dark); margin-bottom:14px;
}
.sec-title-light { color:var(--cream); }
.sec-desc { font-size:15px; color:var(--muted); max-width:500px; line-height:1.75; font-weight:300; }
.sec-desc-light { color:rgba(251,250,245,.5); }

/* ══════════════════════════════════════
   PACKAGES
══════════════════════════════════════ */
.pkg-grid {
  display:grid; grid-template-columns:repeat(4,1fr);
  gap:16px; margin-bottom:32px;
}
.pkg {
  border:1px solid rgba(240,187,12,.15);
  border-radius:var(--r-lg);
  padding:28px 22px 24px;
  position:relative;
  transition:border-color .2s, transform .2s;
  cursor:default;
}
.pkg:hover { border-color:rgba(240,187,12,.5); transform:translateY(-4px); }
.pkg.best { border-color:var(--gold); }
.pkg-star {
  position:absolute; top:-11px; left:50%; transform:translateX(-50%);
  background:var(--gold); color:var(--dark);
  font-size:10px; font-weight:700; letter-spacing:.1em; text-transform:uppercase;
  padding:4px 16px; border-radius:100px; white-space:nowrap;
}
.pkg-dur {
  font-family:'Playfair Display',serif;
  font-size:44px; font-weight:400; color:var(--gold);
  line-height:1; margin-bottom:2px;
}
.pkg-dur sup { font-size:18px; vertical-align:super; }
.pkg-price { font-size:24px; font-weight:700; color:var(--cream); margin-bottom:18px; }
.pkg-price span { font-size:13px; font-weight:400; color:rgba(251,250,245,.4); }
.pkg-divider { height:1px; background:rgba(240,187,12,.12); margin-bottom:18px; }
.pkg-list { list-style:none; display:flex; flex-direction:column; gap:9px; }
.pkg-list li {
  font-size:12.5px; color:rgba(251,250,245,.6);
  display:flex; align-items:flex-start; gap:8px; line-height:1.4;
}
.pkg-list li::before { content:"✦"; color:var(--gold); font-size:8px; margin-top:3px; flex-shrink:0; }
.pkg-btn { margin-top:22px; width:100%; }

.promo-bar {
  background:rgba(240,187,12,.1);
  border:1px solid rgba(240,187,12,.28);
  border-radius:var(--r-lg);
  padding:24px 32px;
  display:flex; align-items:center; justify-content:space-between; gap:20px;
  flex-wrap:wrap;
}
.promo-bar p { color:var(--cream); font-size:15px; font-weight:600; }
.promo-bar small { display:block; color:rgba(251,250,245,.45); font-size:13px; margin-top:3px; font-weight:400; }

/* ══════════════════════════════════════
   INCLUDES GRID
══════════════════════════════════════ */
.inc-grid {
  display:grid; grid-template-columns:repeat(3,1fr); gap:20px;
}
.inc-card {
  background:var(--cream); border:1px solid var(--border);
  border-radius:var(--r-lg); padding:24px;
  display:flex; gap:16px; align-items:flex-start;
  transition:box-shadow .2s, border-color .2s;
}
.inc-card:hover { box-shadow:var(--shadow-md); border-color:var(--gold-border); }
.inc-ico {
  width:42px; height:42px; border-radius:var(--r);
  background:var(--gold-pale); display:flex; align-items:center;
  justify-content:center; font-size:19px; flex-shrink:0;
}
.inc-title { font-size:14px; font-weight:600; color:var(--dark); margin-bottom:4px; }
.inc-desc { font-size:12.5px; color:var(--muted); line-height:1.55; }

/* ══════════════════════════════════════
   CALENDAR + FORM
══════════════════════════════════════ */
.cal-form-grid {
  display:grid; grid-template-columns:1fr 1fr; gap:48px; align-items:start;
}
.cal-box {
  background:var(--cream); border:1px solid var(--border);
  border-radius:var(--r-lg); padding:28px;
  box-shadow:var(--shadow-sm);
}
.cal-top {
  display:flex; align-items:center; justify-content:space-between; margin-bottom:20px;
}
.cal-month-label { font-size:15px; font-weight:600; color:var(--dark); }
.cal-nav { display:flex; gap:6px; }
.cal-nav button {
  width:30px; height:30px; border-radius:var(--r);
  border:1px solid var(--border); background:var(--cream);
  cursor:pointer; font-size:13px; color:var(--ink);
  transition:all .15s; display:flex; align-items:center; justify-content:center;
}
.cal-nav button:hover { background:var(--gold); border-color:var(--gold); }
.cal-grid {
  display:grid; grid-template-columns:repeat(7,1fr); gap:3px;
}
.cal-lbl {
  text-align:center; font-size:10px; font-weight:600;
  letter-spacing:.08em; text-transform:uppercase; color:var(--muted); padding:8px 0;
}
.day {
  aspect-ratio:1; display:flex; align-items:center; justify-content:center;
  font-size:13px; border-radius:var(--r); cursor:pointer;
  color:var(--ink); transition:all .15s; user-select:none;
}
.day:hover:not(.busy):not(.empty) { background:var(--gold-pale); color:var(--gold-hover); }
.day.today { background:var(--gold); color:var(--dark); font-weight:700; }
.day.busy { color:var(--muted); background:rgba(46,42,30,.05); cursor:not-allowed; }
.day.empty { cursor:default; }
.cal-legend {
  display:flex; gap:20px; padding-top:16px; margin-top:12px;
  border-top:1px solid var(--border);
}
.cal-leg-item { display:flex; align-items:center; gap:7px; font-size:11.5px; color:var(--muted); }
.leg-dot { width:9px; height:9px; border-radius:50%; }

/* ── FORM ── */
.form-box {
  background:var(--cream); border:1px solid var(--border);
  border-radius:var(--r-lg); padding:32px;
  box-shadow:var(--shadow-sm);
}
.form-box h3 {
  font-size:20px; color:var(--dark); margin-bottom:24px; font-weight:600;
  font-family:'Playfair Display',serif;
}
.fg { margin-bottom:14px; }
.fg label {
  display:block; font-size:11px; font-weight:600;
  letter-spacing:.07em; text-transform:uppercase; color:var(--muted); margin-bottom:5px;
}
.fg input, .fg select, .fg textarea {
  width:100%; padding:11px 13px;
  border:1px solid rgba(46,42,30,.15); border-radius:var(--r);
  font-family:'Inter',sans-serif; font-size:14px; color:var(--dark);
  background:var(--cream); outline:none; transition:border-color .15s;
}
.fg input:focus,.fg select:focus,.fg textarea:focus {
  border-color:var(--gold); background:var(--white);
}
.fg textarea { resize:vertical; min-height:80px; }
.fg-row { display:grid; grid-template-columns:1fr 1fr; gap:12px; }

/* ══════════════════════════════════════
   GALLERY
══════════════════════════════════════ */
.g-tabs { display:flex; gap:8px; flex-wrap:wrap; margin-bottom:36px; }
.g-tab {
  padding:8px 18px; border-radius:100px; border:1.5px solid var(--border);
  background:transparent; font-family:'Inter',sans-serif; font-size:13px;
  font-weight:500; color:var(--muted); cursor:pointer; transition:all .18s;
}
.g-tab.on,.g-tab:hover { border-color:var(--gold); background:var(--gold-pale); color:var(--gold-hover); }
.g-grid {
  display:grid;
  grid-template-columns:repeat(3,1fr);
  grid-template-rows:auto;
  gap:14px;
}
.g-item {
  border-radius:var(--r-lg); overflow:hidden; cursor:zoom-in;
  position:relative;
}
.g-item:nth-child(1) { grid-row:span 2; }
.g-item:nth-child(4) { grid-column:span 2; }
.g-inner {
  width:100%; height:100%; min-height:180px;
  background:var(--dark2);
  display:flex; align-items:center; justify-content:center;
  flex-direction:column; gap:6px;
  transition:transform .3s;
  position:relative;
}
.g-item:hover .g-inner { transform:scale(1.03); }
.g-inner::after {
  content:''; position:absolute; inset:0;
  background:linear-gradient(180deg,transparent 50%,rgba(23,20,13,.5));
}
.g-label {
  position:absolute; bottom:14px; left:16px; z-index:2;
  font-size:12px; color:rgba(251,250,245,.7); font-style:italic;
  font-family:'Playfair Display',serif;
}
.g-ico { font-size:36px; opacity:.25; position:relative; z-index:1; }

/* ══════════════════════════════════════
   PHOTO ACCESS
══════════════════════════════════════ */
.access-grid { display:grid; grid-template-columns:1fr 1fr; gap:80px; align-items:center; }
.access-widget {
  background:rgba(255,255,255,.04);
  border:1px solid rgba(240,187,12,.15);
  border-radius:var(--r-lg); padding:32px;
}
.access-widget h4 {
  font-family:'Playfair Display',serif; font-size:20px;
  color:var(--cream); font-weight:400; margin-bottom:20px;
}
.code-row { display:flex; gap:8px; }
.code-input {
  flex:1; padding:12px 15px;
  background:rgba(255,255,255,.07);
  border:1px solid rgba(240,187,12,.25); border-radius:var(--r);
  font-family:'Inter',sans-serif; font-size:14px; font-weight:600;
  letter-spacing:.1em; text-transform:uppercase; color:var(--cream); outline:none;
}
.code-input::placeholder { color:rgba(251,250,245,.3); font-weight:400; letter-spacing:.05em; text-transform:none; }
.code-input:focus { border-color:var(--gold); }
.code-hint { font-size:11.5px; color:rgba(251,250,245,.35); margin-top:10px; }
.code-hint strong { color:rgba(240,187,12,.7); }
.recent-list { margin-top:24px; padding-top:20px; border-top:1px solid rgba(240,187,12,.1); }
.recent-label {
  font-size:10px; letter-spacing:.1em; text-transform:uppercase;
  color:rgba(251,250,245,.3); margin-bottom:10px;
}
.recent-item {
  display:flex; align-items:center; gap:10px;
  padding:10px 12px; border-radius:var(--r);
  background:rgba(255,255,255,.04); margin-bottom:6px; cursor:pointer;
  transition:background .15s;
}
.recent-item:hover { background:rgba(240,187,12,.08); }
.recent-item span { font-size:13px; color:rgba(251,250,245,.65); }

/* ══════════════════════════════════════
   HOW IT WORKS
══════════════════════════════════════ */
.steps { display:grid; grid-template-columns:repeat(3,1fr); gap:32px; position:relative; margin-top:60px; }
.steps::before {
  content:''; position:absolute; top:30px;
  left:calc(16.7% + 20px); right:calc(16.7% + 20px);
  height:1px; background:linear-gradient(90deg,transparent,var(--gold-border),var(--gold),var(--gold-border),transparent);
}
.step { text-align:center; }
.step-num {
  width:60px; height:60px; border-radius:50%;
  background:var(--gold); color:var(--dark);
  font-family:'Playfair Display',serif; font-size:22px; font-weight:700;
  display:flex; align-items:center; justify-content:center;
  margin:0 auto 22px; position:relative; z-index:1;
  box-shadow:0 4px 20px rgba(240,187,12,.35);
}
.step-title { font-size:18px; font-weight:600; color:var(--dark); margin-bottom:10px; }
.step-desc { font-size:14px; color:var(--muted); line-height:1.65; }

/* ══════════════════════════════════════
   REVIEWS
══════════════════════════════════════ */
.rev-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:20px; margin-top:52px; }
.rev-card {
  background:rgba(255,255,255,.04);
  border:1px solid rgba(240,187,12,.12);
  border-radius:var(--r-lg); padding:28px;
  transition:border-color .2s;
}
.rev-card:hover { border-color:rgba(240,187,12,.35); }
.rev-stars { color:var(--gold); font-size:13px; letter-spacing:3px; margin-bottom:14px; }
.rev-text {
  font-family:'Playfair Display',serif; font-style:italic;
  font-size:16px; font-weight:400; line-height:1.65;
  color:rgba(251,250,245,.8); margin-bottom:20px;
}
.rev-author { display:flex; align-items:center; gap:12px; }
.rev-av {
  width:36px; height:36px; border-radius:50%;
  background:linear-gradient(135deg,var(--gold),var(--gold-hover));
  display:flex; align-items:center; justify-content:center;
  font-size:12px; font-weight:700; color:var(--dark); flex-shrink:0;
}
.rev-name { font-size:13px; font-weight:600; color:var(--cream); }
.rev-event { font-size:11px; color:rgba(251,250,245,.35); margin-top:2px; }

/* ══════════════════════════════════════
   ADVANTAGES
══════════════════════════════════════ */
.adv-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:18px; margin-top:52px; }
.adv {
  background:var(--cream); border:1px solid var(--border);
  border-radius:var(--r-lg); padding:28px 20px;
  text-align:center; transition:all .2s;
}
.adv:hover { box-shadow:var(--shadow-md); border-color:var(--gold-border); transform:translateY(-3px); }
.adv-ico {
  width:50px; height:50px; border-radius:50%;
  background:var(--gold-pale); margin:0 auto 14px;
  display:flex; align-items:center; justify-content:center; font-size:22px;
}
.adv-title { font-size:13.5px; font-weight:600; color:var(--dark); margin-bottom:6px; }
.adv-desc { font-size:12px; color:var(--muted); line-height:1.55; }

/* ══════════════════════════════════════
   FAQ
══════════════════════════════════════ */
.faq-wrap { max-width:740px; margin-top:52px; }
.faq-item { border-bottom:1px solid var(--border); }
.faq-btn {
  width:100%; text-align:left; background:none; border:none;
  cursor:pointer; padding:20px 0;
  display:flex; justify-content:space-between; align-items:center; gap:16px;
  font-family:'Inter',sans-serif; font-size:15px; font-weight:500; color:var(--dark);
  transition:color .15s;
}
.faq-btn:hover { color:var(--gold-hover); }
.faq-ico {
  width:26px; height:26px; flex-shrink:0; border-radius:50%;
  background:var(--gold-pale); display:flex; align-items:center; justify-content:center;
  font-size:17px; color:var(--gold-hover); line-height:1; transition:transform .2s, background .2s;
}
.faq-item.open .faq-ico { transform:rotate(45deg); background:var(--gold); color:var(--dark); }
.faq-ans {
  font-size:14px; color:var(--muted); line-height:1.75;
  max-height:0; overflow:hidden; transition:max-height .3s ease, padding .3s;
}
.faq-item.open .faq-ans { max-height:200px; padding-bottom:18px; }

/* ══════════════════════════════════════
   CONTACT
══════════════════════════════════════ */
.contact-grid { display:grid; grid-template-columns:1fr 420px; gap:80px; align-items:start; }
.ch-list { display:flex; flex-direction:column; gap:0; margin-top:32px; }
.ch-link {
  display:flex; align-items:center; gap:16px;
  padding:16px 0; border-bottom:1px solid rgba(240,187,12,.1);
  text-decoration:none; transition:border-color .15s;
}
.ch-link:hover { border-color:rgba(240,187,12,.35); }
.ch-ico {
  width:40px; height:40px; flex-shrink:0; border-radius:var(--r);
  background:rgba(240,187,12,.1);
  display:flex; align-items:center; justify-content:center; font-size:18px;
}
.ch-lbl { font-size:10px; letter-spacing:.08em; text-transform:uppercase; color:var(--muted); }
.ch-val { font-size:14px; font-weight:500; color:var(--cream); margin-top:2px; }
.cform {
  background:rgba(255,255,255,.04);
  border:1px solid rgba(240,187,12,.15);
  border-radius:var(--r-lg); padding:32px;
}
.cform h3 { font-family:'Playfair Display',serif; font-size:20px; color:var(--cream); font-weight:400; margin-bottom:24px; }
.cform .fg input, .cform .fg select, .cform .fg textarea {
  background:rgba(255,255,255,.06); border-color:rgba(240,187,12,.2); color:var(--cream);
}
.cform .fg input::placeholder, .cform .fg textarea::placeholder { color:rgba(251,250,245,.28); }
.cform .fg input:focus,.cform .fg select:focus,.cform .fg textarea:focus {
  border-color:var(--gold); background:rgba(255,255,255,.1);
}
.cform .fg label { color:rgba(251,250,245,.45); }
.cform .fg select option { background:var(--dark); }

/* ══════════════════════════════════════
   FOOTER
══════════════════════════════════════ */
footer {
  background:var(--dark);
  border-top:1px solid rgba(240,187,12,.1);
  padding:36px 32px;
}
.foot-in {
  max-width:1160px; margin:0 auto;
  display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:20px;
}
.foot-brand { display:flex; align-items:center; gap:10px; }
.foot-brand img { width:34px; height:34px; border-radius:0; object-fit:contain; }
.foot-name { font-family:'Playfair Display',serif; font-size:15px; color:var(--cream); }
.foot-sub { font-size:10px; color:rgba(251,250,245,.3); letter-spacing:.1em; text-transform:uppercase; }
.foot-links { display:flex; gap:24px; flex-wrap:wrap; }
.foot-links a { font-size:12px; color:rgba(251,250,245,.4); text-decoration:none; transition:color .15s; }
.foot-links a:hover { color:var(--gold); }
.foot-copy { font-size:11px; color:rgba(251,250,245,.22); }

/* ══════════════════════════════════════
   RESPONSIVE
══════════════════════════════════════ */
@media(max-width:980px){
  .hero-grid { grid-template-columns:1fr; min-height:auto; }
  .hero-left { padding:60px 32px 40px; margin-left:0; max-width:100%; }
  .hero-right { min-height:340px; }
  .pkg-grid { grid-template-columns:1fr 1fr; }
  .inc-grid { grid-template-columns:1fr 1fr; }
  .cal-form-grid,.access-grid,.contact-grid { grid-template-columns:1fr; }
  .steps::before { display:none; }
  .steps { grid-template-columns:1fr; gap:28px; }
  .rev-grid { grid-template-columns:1fr 1fr; }
  .adv-grid { grid-template-columns:repeat(2,1fr); }
  .g-grid { grid-template-columns:1fr 1fr; }
  .g-item:nth-child(1) { grid-row:span 1; }
  .g-item:nth-child(4) { grid-column:span 1; }
}
@media(max-width:600px){
  .pkg-grid,.inc-grid,.rev-grid,.adv-grid { grid-template-columns:1fr; }
  #nav .nav-links { display:none; }
  .hero-btns { flex-direction:column; align-items:flex-start; }
  .hero-pills { gap:8px; }
  .g-grid { grid-template-columns:1fr; }
  .contact-grid { grid-template-columns:1fr; }
}

/* ── ANIMATION ── */
@keyframes fadeUp { from{opacity:0;transform:translateY(20px)} to{opacity:1;transform:translateY(0)} }
.fu { animation:fadeUp .65s ease both; }
.fu1{animation-delay:.08s}.fu2{animation-delay:.16s}.fu3{animation-delay:.24s}.fu4{animation-delay:.32s}

/* ── HAMBURGER ── */
.hamburger {
  display:none;
  flex-direction:column; justify-content:center; align-items:center;
  gap:5px; width:38px; height:38px;
  background:none; border:none; cursor:pointer; padding:4px;
  border-radius:var(--r); transition:background .15s;
}
.hamburger:hover { background:var(--gold-pale); }
.hamburger span {
  display:block; width:22px; height:2px;
  background:var(--dark); border-radius:2px;
  transition:all .25s;
}
.hamburger.open span:nth-child(1) { transform:translateY(7px) rotate(45deg); }
.hamburger.open span:nth-child(2) { opacity:0; }
.hamburger.open span:nth-child(3) { transform:translateY(-7px) rotate(-45deg); }

/* ── MOBILE MENU ── */
.mobile-menu {
  position:fixed; top:0; right:0; bottom:0; z-index:300;
  width:280px; max-width:85vw;
  background:var(--cream);
  box-shadow:-8px 0 40px rgba(23,20,13,.15);
  padding:80px 32px 40px;
  transform:translateX(100%);
  transition:transform .3s cubic-bezier(.4,0,.2,1);
  display:flex; flex-direction:column;
}
.mobile-menu.open { transform:translateX(0); }
.mobile-menu-close {
  position:absolute; top:18px; right:18px;
  width:36px; height:36px; border-radius:50%;
  background:rgba(251,250,245,.6); border:1px solid var(--border);
  font-size:16px; cursor:pointer; color:var(--muted);
  display:flex; align-items:center; justify-content:center;
  transition:all .15s;
}
.mobile-menu-close:hover { background:var(--dark); color:var(--white); }
.mobile-menu-nav {
  display:flex; flex-direction:column; gap:4px;
}
.mm-link {
  font-size:17px; font-weight:500; color:var(--ink);
  text-decoration:none; padding:13px 0;
  border-bottom:1px solid var(--border);
  transition:color .15s;
  font-family:'Playfair Display',serif;
}
.mm-link:hover { color:var(--gold-hover); }
.mm-cta {
  margin-top:20px; border:none;
  background:var(--gold); color:var(--dark);
  text-align:center; padding:14px;
  border-radius:var(--r); font-weight:700;
  font-family:'Inter',sans-serif; font-size:15px;
  box-shadow:0 4px 18px rgba(240,187,12,.35);
}
.mm-cta:hover { background:var(--gold-hover); color:var(--dark); }
.mobile-menu-overlay {
  position:fixed; inset:0; z-index:299;
  background:rgba(23,20,13,.45);
  opacity:0; pointer-events:none;
  transition:opacity .3s;
}
.mobile-menu-overlay.open { opacity:1; pointer-events:all; }

@media(max-width:900px) {
  .hamburger { display:flex; }
  #nav .nav-links { display:none; }
  #nav .nav-actions { display:none; }
}
.nav-btns .btn-gold { padding:6px 14px; font-size:12px; font-weight:600; box-shadow:none; }
.nav-btns .btn-outline { padding:5px 12px; font-size:12px; }
.btn-pkg {
  background:transparent;
  color:var(--gold);
  border:1.5px solid var(--gold);
  padding:11px 24px;
  border-radius:var(--r);
  font-size:14px; font-weight:600;
  transition:all .18s;
  text-decoration:none;
  display:inline-flex; align-items:center; justify-content:center;
}
.btn-pkg:hover, .btn-pkg:active {
  background:var(--gold);
  color:var(--dark);
  box-shadow:0 4px 18px rgba(240,187,12,.4);
}
</style>
</head>
<body>

<!-- ═══════════════ NAV ═══════════════ -->
<nav id="nav">
  <div class="nav-in">
    <a href="#" class="nav-brand"><img src="data:image/svg+xml;base64," alt="Oglinda Oglinjoara"></a>
    <ul class="nav-links">
      <li><a href="#pachete">Pachete</a></li>
      <li><a href="#rezervare">Rezervare</a></li>
      <li><a href="#galerie">Galerie</a></li>
      <li><a href="#recenzii">Recenzii</a></li>
      <li><a href="#faq">FAQ</a></li>
    </ul>
    <div class="nav-actions nav-btns">
      <a href="#contact" class="btn btn-outline">Contact</a>
      <a href="#rezervare" class="btn btn-gold">Rezervă data</a>
    </div>
    <button class="hamburger" id="menuBtn" aria-label="Meniu">
      <span></span><span></span><span></span>
    </button>
  </div>
</nav>

<!-- ═══════════════ HERO ═══════════════ -->
<section class="hero">
  <div class="hero-grid">

    <!-- LEFT -->
    <div class="hero-left">
      <div class="eyebrow fu"><span class="eyebrow-line"></span>Photo Booth Premium · Moldova</div>
      <hr style="border:none;border-top:1.5px solid rgba(46,42,30,0.12);margin:18px auto 22px;width:80px;">
      <h1 class="hero-title fu fu1">
        Amintiri printate<br><em>instant</em> la<br>evenimentul tău
      </h1>
      <p class="hero-sub fu fu2">
        Transformăm fiecare moment special într-o amintire de neprețuit. Fotografii printate instant pe care invitații le iau acasă — plus galerie digitală completă, album cadou și distracție garantată pentru toți!
      </p>
      <div class="hero-btns fu fu3">
        <a href="#rezervare" class="btn btn-gold">Rezervă acum</a>
        <a href="#pachete" class="btn btn-outline">Vezi pachetele</a>
      </div>
      <div class="hero-pills fu fu4">
        <div class="hero-pill"><span class="hero-pill-dot"></span>Fotografii printate instant</div>
        <div class="hero-pill"><span class="hero-pill-dot"></span>Album cadou inclus</div>
        <div class="hero-pill"><span class="hero-pill-dot"></span>Oglindă slim</div>
        <div class="hero-pill"><span class="hero-pill-dot"></span>Prețuri accesibile</div>
        <div class="hero-pill"><span class="hero-pill-dot"></span>Toată Moldova</div>
      </div>
    </div>



  </div>
</section>

<!-- ═══════════════ PACKAGES ═══════════════ -->
<section class="sec sec-dark" id="pachete">
  <div class="wrap">
    <div class="sec-head">
      <div class="eyebrow" style="color:var(--gold)"><span class="eyebrow-line"></span>Pachete &amp; Prețuri</div>
      <h2 class="sec-title sec-title-light">Alege pachetul potrivit<br>pentru evenimentul tău</h2>
      <p class="sec-desc sec-desc-light">Toate pachetele includ fotografii printate instant, digitale, recuzită, asistent și album cadou.</p>
    </div>
    <div class="pkg-grid">
      <div class="pkg">
        <div class="pkg-dur">2<sup>ore</sup></div>
