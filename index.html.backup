<!-- ═══ CALENDAR DINAMIC FIREBASE ═══ -->
<script type="module">
  import { initializeApp } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-app.js";
  import { getFirestore, collection, getDocs } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-firestore.js";

  const firebaseConfig = {
    apiKey: "AIzaSyDEkNgNQfM5BNr3e1Pr109MYjMhSYVGL2o",
    authDomain: "oglinda-38c3d.firebaseapp.com",
    projectId: "oglinda-38c3d",
    storageBucket: "oglinda-38c3d.firebasestorage.app",
    messagingSenderId: "105428420310",
    appId: "1:105428420310:web:fb1b7b0d408eb913a3ab77"
  };

  const MONTHS_RO = ["Ianuarie","Februarie","Martie","Aprilie","Mai","Iunie",
                     "Iulie","August","Septembrie","Octombrie","Noiembrie","Decembrie"];

  let app, db;
  try {
    app = initializeApp(firebaseConfig);
    db  = getFirestore(app);
    console.log("✅ Firebase conectat");
  } catch(e) {
    console.error("❌ Firebase init error:", e);
  }

  async function loadOccupiedDates() {
    if (!db) return new Set();
    try {
      const snapshot = await getDocs(collection(db, "calendar"));
      const occupied = new Set();
      snapshot.forEach(doc => {
        const data = doc.data();
        console.log("📅 Doc:", doc.id, data);
        if (data.status === "ocupat") occupied.add(doc.id);
      });
      console.log("✅ Date ocupate:", [...occupied]);
      window._occupiedDates = occupied;
      return occupied;
    } catch(e) {
      console.error("❌ Firestore read error:", e.code, e.message);
      return new Set();
    }
  }

  function getDaysInMonth(year, month) {
    return new Date(year, month, 0).getDate();
  }

  function getFirstDayOfMonth(year, month) {
    let d = new Date(year, month - 1, 1).getDay();
    return d === 0 ? 6 : d - 1;
  }

  async function buildCalendar(year, month) {
    console.log("🗓 Building calendar:", year, month);
    const occupied = await loadOccupiedDates();
    const calGrid  = document.querySelector(".cal-grid");
    if (!calGrid) { console.error("❌ .cal-grid not found"); return; }

    const today    = new Date();
    const labels   = [...calGrid.querySelectorAll(".cal-lbl")];
    calGrid.innerHTML = "";
    labels.forEach(l => calGrid.appendChild(l.cloneNode(true)));

    const firstDay    = getFirstDayOfMonth(year, month);
    const daysInMonth = getDaysInMonth(year, month);

    for (let i = 0; i < firstDay; i++) {
      const e = document.createElement("div");
      e.className = "day empty";
      calGrid.appendChild(e);
    }

    for (let d = 1; d <= daysInMonth; d++) {
      const el  = document.createElement("div");
      const key = `${year}-${String(month).padStart(2,"0")}-${String(d).padStart(2,"0")}`;
      el.className = "day";
      el.textContent = d;

      if (occupied.has(key)) {
        el.classList.add("busy");
        el.title = "Rezervat";
      } else if (
        year  === today.getFullYear() &&
        month === today.getMonth() + 1 &&
        d     === today.getDate()
      ) {
        el.classList.add("today");
      } else {
        el.style.cursor = "pointer";
        el.addEventListener("click", () => {
          const inp = document.querySelector("input[type=date]");
          if (inp) { inp.value = key; }
          document.getElementById("rezervare")?.scrollIntoView({behavior:"smooth"});
        });
      }
      calGrid.appendChild(el);
    }

    const lbl = document.querySelector(".cal-month-label");
    if (lbl) lbl.textContent = `${MONTHS_RO[month - 1]} ${year}`;
  }

  let curYear  = new Date().getFullYear();
  let curMonth = new Date().getMonth() + 1;
  buildCalendar(curYear, curMonth);

  const navBtns = document.querySelectorAll(".cal-nav button");
  navBtns[0]?.addEventListener("click", () => {
    curMonth--; if (curMonth < 1) { curMonth = 12; curYear--; }
    buildCalendar(curYear, curMonth);
  });
  navBtns[1]?.addEventListener("click", () => {
    curMonth++; if (curMonth > 12) { curMonth = 1; curYear++; }
    buildCalendar(curYear, curMonth);
  });
</script>

<script>
  // ── Blocked dates shared with Firebase calendar ──
  window._occupiedDates = new Set();

  // ── Date input: min=today + block occupied ──
  document.addEventListener("DOMContentLoaded", () => {
    const dateInp = document.getElementById("dateInput");
    const warning = document.getElementById("dateWarning");
    if (!dateInp) return;
    dateInp.min = new Date().toISOString().split("T")[0];
    dateInp.addEventListener("change", () => {
      if (window._occupiedDates.has(dateInp.value)) {
        if(warning) warning.style.display = "block";
        dateInp.style.borderColor = "#c0392b";
        dateInp.value = "";
        setTimeout(() => {
          if(warning) warning.style.display = "none";
          dateInp.style.borderColor = "";
        }, 4000);
      } else {
        if(warning) warning.style.display = "none";
        dateInp.style.borderColor = "";
      }
    });
  });

  // ── Helper: send to Netlify function ──
  async function sendRequest(payload) {
    const res = await fetch("/.netlify/functions/send-telegram", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify(payload)
    });
    const data = await res.json();
    if (!data.ok) throw new Error(data.error || "Eroare server");
    return data;
  }

  // ── Formular REZERVARE ──
  async function submitForm(e) {
    e.preventDefault();
    const btn     = document.getElementById("submitBtn");
    const success = document.getElementById("formSuccess");
    const error   = document.getElementById("formError");

    const payload = {
      name:       document.querySelector('.form-box input[placeholder="Prenume Nume"]')?.value?.trim(),
      phone:      document.querySelector('.form-box input[placeholder="+373 xxx xxx"]')?.value?.trim(),
      email:      document.querySelector('.form-box input[type="email"]')?.value?.trim(),
      event_type: document.querySelectorAll('.form-box select')[0]?.value,
      event_date: document.getElementById("dateInput")?.value,
      package:    document.querySelectorAll('.form-box select')[1]?.value,
      guests:     document.querySelector('.form-box input[type="number"]')?.value,
      message:    document.querySelector('.form-box textarea')?.value?.trim(),
      is_offer:   false
    };

    if (!payload.name || !payload.phone || !payload.event_date) {
      alert("Te rugăm completează: Nume, Telefon și Data evenimentului.");
      return;
    }
    if (window._occupiedDates.has(payload.event_date)) {
      alert("Această dată este deja rezervată. Te rugăm alege altă dată.");
      return;
    }

    btn.disabled = true;
    btn.textContent = "⏳ Se trimite...";
    success.style.display = "none";
    error.style.display   = "none";

    try {
      await sendRequest(payload);
      success.style.display = "block";
      btn.style.display     = "none";
      document.querySelectorAll('.form-box input:not([type="submit"]), .form-box textarea').forEach(el => el.value = "");
    } catch(err) {
      console.error("Rezervare error:", err);
      error.style.display = "block";
      error.innerHTML = `❌ Eroare la trimitere. Contactează-ne pe <a href="https://wa.me/37360225455" style="color:#991b1b;font-weight:600">WhatsApp</a>.`;
      btn.disabled = false;
      btn.textContent = "Trimite cererea →";
    }
  }

  // ── Formular CONTACT (Solicită ofertă) ──
  async function submitContact(e) {
    e.preventDefault();
    const btn     = document.getElementById("contactBtn");
    const success = document.getElementById("contactSuccess");
    const error   = document.getElementById("contactError");

    const cform = document.querySelector(".cform");
    if (!cform) { console.error("cform not found"); return; }

    const allInputs = cform.querySelectorAll("input");
    const textarea  = cform.querySelector("textarea");

    const payload = {
      name:     allInputs[0]?.value?.trim(),
      phone:    allInputs[1]?.value?.trim(),
      email:    allInputs[2]?.value?.trim(),
      message:  textarea?.value?.trim(),
      is_offer: true
    };

    if (!payload.name || !payload.phone) {
      alert("Te rugăm completează cel puțin Numele și Telefonul.");
      return;
    }

    btn.disabled = true;
    btn.textContent = "⏳ Se trimite...";
    success.style.display = "none";
    error.style.display   = "none";

    try {
      await sendRequest(payload);
      success.style.display = "block";
      btn.style.display     = "none";
      cform.querySelectorAll("input, textarea").forEach(el => el.value = "");
    } catch(err) {
      console.error("Contact error:", err);
      error.style.display = "block";
      btn.disabled = false;
      btn.textContent = "Solicită ofertă →";
    }
  }
</script>
</body>
</html>